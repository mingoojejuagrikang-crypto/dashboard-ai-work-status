{
  "name": "mypka-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "대시보드_AI_작업현황 — AI 작업 프로젝트별 현황과 변경이력을 마크다운에서 집계해 보여주는 단일 페이지 대시보드",
  "type": "module",
  "scripts": {
    "build": "node generate.mjs",
    "publish": "sh deploy.sh",
    "serve": "node -e \"import('node:http').then(({default:h})=>import('node:fs').then(({readFileSync,existsSync})=>h.createServer((q,s)=>{const u=new URL(q.url,'http://127.0.0.1');const p=u.pathname==='/'?'/index.html':u.pathname;const f='dist'+p;if(existsSync(f)){s.writeHead(200);s.end(readFileSync(f))}else{s.writeHead(404);s.end('not found')}}).listen(8899,()=>console.log('http://127.0.0.1:8899'))))\""
  }
}
